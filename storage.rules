rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Firebase Storage Security Rules — DENY ALL (initial scaffold)
//
// All reads and writes are denied by default.
// Granular rules (e.g. authenticated upload, size limits, MIME type checks)
// will be implemented in Phase 2.
//
// IMPORTANT: Do not relax these rules until proper auth checks are in place.
// ─────────────────────────────────────────────────────────────────────────────

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
