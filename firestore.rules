rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── users ──────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // ── folders + boys + binders ───────────────────────────────────────────────
    // הוספתי גישת כתיבה מלאה כדי שתוכל ליצור קלסרים ולערוך בחורים מהדאשבורד
    match /folders/{folderId} {
      allow read, write: if true;
    }

    match /binders/{docId} {
      allow read, write: if true;
    }

    match /boys/{boyId} {
      allow read, write: if true;
    }

    // ── settings (כאן יישמר הטיקר) ──────────────────────────────────────────────
    match /settings/{docId} {
      allow read, write: if true;
    }

    // ── pending_transactions ────────────────────────────────────────────────────
    match /pending_transactions/{docId} {
      allow create: if true; // פתוח לאמולטור כדי שלא יחסום עסקאות
    }

    // ── transactions ────────────────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if true;
      allow update: if true;
    }
  }
}