rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Firestore Security Rules — DENY ALL (initial scaffold)
//
// All reads and writes are denied by default.
// Granular, role-based rules will be implemented in Phase 2 once the
// authentication layer and data model are confirmed.
//
// IMPORTANT: Do not relax these rules until proper auth checks are in place.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
