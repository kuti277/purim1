# ─────────────────────────────────────────────────────────────────────────────
# apps/dashboard — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must NEVER be committed.
#
# Where to find these values:
#   Firebase Console → Project Settings → General → Your apps → Web app
#   https://console.firebase.google.com/project/<your-project>/settings/general
# ─────────────────────────────────────────────────────────────────────────────

# Firebase Web App Configuration
# All VITE_ variables are injected into the browser bundle at build time.
# They are intentionally public — Firebase security is enforced by
# Firestore rules and Firebase Auth, not by hiding these keys.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Emulator flags (local development only) ─────────────────────────────────
# Set to "true" to connect to the local Firebase Emulator Suite instead of
# production. Leave empty or omit entirely in production builds.

VITE_USE_FIREBASE_EMULATOR=true
